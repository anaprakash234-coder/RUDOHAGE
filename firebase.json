{
  "hosting": {
    "public": ".",
    "redirects": [
      {
        "source": "https://rudohage.firebaseapp.com/**",
        "destination": "https://rudohage.com/**",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/__/auth/**",
        "destination": "/__/auth/index.html"
      }
    ]
  }
}
